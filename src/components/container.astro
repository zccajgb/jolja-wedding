---
import Layout from "../layouts/layout.astro";
import "../styles/global.css";
---

<Layout>
  <div class="flex flex-col">
    <div
      class="mx-4 my-6 sm:mx-auto sm:max-w-[50%] flex flex-col gap-4 sm:gap-6 sm:border-10 sm:border-bone sm:bg-bone sm:shadow shadow-black"
    >
      <div class="sm:border-10 border-burgundy p-6 pt-6 ">
        <slot />
      </div>
    </div>
  </div>
</Layout>
<style>
  p {
    font-size: var(--text-sm) /* 0.875rem = 14px */;
    line-height: var(
      --tw-leading,
      var(--text-sm--line-height) /* calc(1.25 / 0.875) ≈ 1.4286 */
    );
  }
</style>
