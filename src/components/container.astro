---
import Layout from '../layouts/layout.astro';
import '../styles/global.css';
---
<Layout>
  <div class="flex flex-col">
    <div class="mx-4 my-6 sm:mx-auto p-6 pt-6 sm:max-w-[50%] flex flex-col gap-4 sm:gap-6 rounded-md sm:border-20 sm:border-burgundy paper">
      <slot />
    </div>
  </div>
</Layout>
<style>
  p {
    font-size: var(--text-sm) /* 0.875rem = 14px */;
    line-height: var(--tw-leading, var(--text-sm--line-height) /* calc(1.25 / 0.875) ≈ 1.4286 */)
  }
</style>