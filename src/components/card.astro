---
const { site_name, url, theme, screenshot } = Astro.props;
---
<div 
  class="card border border-stone-400 bg-stone-100 dark:border-gray-500 dark:bg-gray-700 rounded-sm p-4 dark:text-stone-100"
  onclick={`window.open('${url}', '_blank')`}
>
  <div class="mt-3 text-lg">{site_name}</div>
  <div class="flex w-full">
    <div class="overflow-hidden mx-auto mt-3 border border-stone-200">
      <img src={screenshot} alt={site_name} class="w-full h-full object-contain" />
    </div>
  </div>
  <div class="mt-2 text-xs h-8">
    {theme} 
  </div> 
</div>
<style>
  iframe {
    width: 1080px; /* tailwind 270 */
    height: 720px; /* tailwind 270 */
    border: none;
    pointer-events: none;       
    transform: scale(0.326);     
    transform-origin: 0 0;    
    position: relative;
    /* top: 0; */
    /* left: 0; */
  }

  .card {
    transition: transform 0.3s ease;
    /* other styling */
  }

  .card:hover {
    transform: scale(1.02);
    cursor: pointer;
  }
</style>